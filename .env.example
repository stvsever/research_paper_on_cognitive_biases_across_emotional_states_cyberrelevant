# --- Project mode ---
PROJECT_NAME=cbias-emotion-workflow
ENVIRONMENT=development

# --- LLM/API keys (set only what you use) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-3-flash-preview
OPENROUTER_FALLBACK_MODEL=mistralai/mistral-small-3.1-24b-instruct
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Literature/retrieval API keys (optional) ---
NCBI_EMAIL=
NCBI_API_KEY=
CLARIVATE_API_KEY=
EDS_API_USER=
EDS_API_PASSWORD=
EDS_API_PROFILE=
EDS_API_ORG=

# --- Paths ---
PREREG_PATH=src/protocol/osf/osf_preregistration.md
TAXONOMY_PATH=src/ontologies/taxonomy/taxonomy_cognitive_biases_cyberrelevant.json
